# ──────────────────────────────────────────────────────────────
# clients/web/.gitignore — Vue 3 / Vite / Node
# ──────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment — contains secrets (Auth0, API URL, …)
# Template is .env.example ; real values go in .env, never committed
.env
.env.local
.env.*.local

# Vite cache
.vite/

# TypeScript incremental build cache
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/
