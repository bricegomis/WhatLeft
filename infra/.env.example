# ─────────────────────────────────────────────────────────────────────────────
# infra/.env.example  —  copy to infra/.env and fill in real values
# Never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=XXX.auth0.com
AUTH0_AUDIENCE=https://domain
AUTH0_CLIENT_ID=XXX

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DB_CONNECTION_STRING=Host=xxx.neon.tech;Database=whatleft;Username=xxx;Password=xxx;Ssl Mode=Require

# ── Public-facing URLs (used by Nginx Proxy Manager) ─────────────────────────
# API_URL   : the URL the *browser* uses to call the backend
# FRONTEND_URL : whitelisted in CORS on the backend
API_URL=https://api.whatleft.example.com
FRONTEND_URL=https://whatleft.example.com
